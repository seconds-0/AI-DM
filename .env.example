# Discord Bot Configuration
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# URL for the Storyteller Flow (Genkit endpoint)
# For local development with 'genkit start', this is usually http://localhost:3400/storytellerFlow (default port)
# For deployed functions, this will be the Firebase Cloud Function URL.
STORYTELLER_FLOW_URL=http://localhost:3400/storytellerFlow

# Google Cloud Configuration (for Genkit server-side and potentially bot client libraries)
# If running locally and using Application Default Credentials (ADC) via 'gcloud auth application-default login',
# GOOGLE_APPLICATION_CREDENTIALS might not be needed explicitly by the Genkit backend for Firebase and Google AI services.
# However, client libraries used directly in the bot for other Google Cloud services (if any were added beyond Genkit's abstractions)
# might need it, or if running in an environment where ADC isn't easily available.
# For Genkit with Firebase, ensure your environment is logged into gcloud and has selected a project with Firebase enabled.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Genkit Configuration (usually managed by Genkit itself or via Firebase project initialization)
# These are typically not set directly in .env but are good to be aware of.
# GENKIT_ENV=dev # or 'prod' (Genkit uses this to manage environments, e.g., for different Firebase projects)
# FIREBASE_PROJECT_ID=your-firebase-project-id # Often picked up from gcloud CLI, Firebase CLI, or environment (e.g., in Cloud Functions)
# GCLOUD_PROJECT=your-gcloud-project-id # Alias for FIREBASE_PROJECT_ID often used by Google Cloud libraries
